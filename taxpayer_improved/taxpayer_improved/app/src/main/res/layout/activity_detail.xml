<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.DetailActivity">

    <!-- شريط الأدوات -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="@string/taxpayer_details"
        app:titleTextColor="@color/textOnPrimary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/textOnPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_normal">

            <!-- رأس البطاقة: الاسم + النوع -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_normal">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    tools:text="محمد أحمد الحسن" />

                <TextView
                    android:id="@+id/tvTypeChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    tools:text="قديم" />

            </LinearLayout>

            <!-- بطاقة البيانات الأساسية -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="البيانات الأساسية"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="@dimen/margin_medium" />

                    <!-- الرقم الضريبي -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tax_number"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvTaxNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="123456789" />

                    <!-- رقم الهوية -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/id_number"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvIdNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="9876543210" />

                    <!-- الهاتف -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="0912345678" />

                    <!-- العنوان -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/address"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="حي المزة - شارع الفيلات" />

                    <!-- نوع النشاط -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_type"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvActivityType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="تجارة عامة" />

                    <!-- الحالة -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_label"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        tools:text="نشط" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- بطاقة تعريف المحل -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تعريف المحل"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="@dimen/margin_medium" />

                    <!-- الجار الأيمن -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/neighbor_right"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvNeighborRight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="محل خالد" />

                    <!-- الجار الأيسر -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/neighbor_left"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvNeighborLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="@dimen/margin_medium"
                        tools:text="محل أحمد" />

                    <!-- وصف المحل -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shop_description"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvShopDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        tools:text="محل ألبسة - طابق أرضي" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- بطاقة الملاحظات -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notes"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <TextView
                        android:id="@+id/tvNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textPrimary"
                        tools:text="ملاحظات حول المكلف" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- بطاقة الموقع -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الموقع GPS"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="@dimen/margin_medium" />

                    <!-- لا يوجد موقع -->
                    <TextView
                        android:id="@+id/tvNoLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_location"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/textSecondary"
                        android:visibility="gone" />

                    <!-- قسم الموقع المتاح -->
                    <LinearLayout
                        android:id="@+id/locationAvailableLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- خط العرض -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/margin_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="خط العرض: "
                                android:textSize="@dimen/text_size_body"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvLatitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_body"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                tools:text="33.51234567" />

                        </LinearLayout>

                        <!-- خط الطول -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/margin_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="خط الطول: "
                                android:textSize="@dimen/text_size_body"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvLongitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_body"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                tools:text="36.29876543" />

                        </LinearLayout>

                        <!-- الدقة -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/margin_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="الدقة: "
                                android:textSize="@dimen/text_size_body"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvAccuracy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_body"
                                android:textStyle="bold"
                                tools:text="8 متر" />

                            <TextView
                                android:id="@+id/tvAccuracyLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_small"
                                android:layout_marginStart="8dp"
                                tools:text="(دقة فائقة)" />

                        </LinearLayout>

                        <!-- وقت الالتقاط -->
                        <TextView
                            android:id="@+id/tvCapturedAt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/textSecondary"
                            android:layout_marginBottom="@dimen/margin_medium"
                            tools:text="وقت الالتقاط: 2024-01-15 14:30:00" />

                        <!-- أزرار الخريطة -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewMap"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="عرض على الخريطة"
                                app:icon="@drawable/ic_location" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnOpenGoogleMaps"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:text="@string/open_in_google_maps" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- أزرار الإجراءات السفلية -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/padding_normal"
        android:background="@color/surface"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/edit"
            app:backgroundTint="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/delete"
            app:backgroundTint="@color/error" />

    </LinearLayout>

</LinearLayout>
