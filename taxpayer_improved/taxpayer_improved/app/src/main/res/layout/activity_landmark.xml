<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.LandmarkActivity">

    <!-- شريط الأدوات -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="@string/add_landmark"
        app:titleTextColor="@color/textOnPrimary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/textOnPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_normal">

            <!-- === بيانات المعلم === -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/landmark_info_section"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/margin_medium" />

            <!-- اسم المعلم -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:hint="@string/landmark_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- نوع المعلم -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/landmark_type"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="@dimen/margin_small" />

            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/margin_normal" />

            <!-- المنطقة -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/landmark_area"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="@dimen/margin_small" />

            <Spinner
                android:id="@+id/spinnerArea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/margin_small" />

            <!-- حقل المنطقة المخصص (يظهر عند اختيار "أخرى") -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:hint="@string/landmark_area_custom"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAreaCustom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:visibility="gone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- وصف المعلم -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:hint="@string/landmark_description">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- معلم رئيسي -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbMainReference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/landmark_is_main"
                android:textSize="@dimen/text_size_body"
                android:layout_marginBottom="@dimen/margin_normal" />

            <!-- === قسم الموقع GPS === -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/landmark_location_section"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/margin_medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_location_section"
                android:padding="@dimen/padding_normal"
                android:layout_marginBottom="@dimen/margin_normal">

                <TextView
                    android:id="@+id/tvLocationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_location"
                    android:textSize="@dimen/text_size_body"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:id="@+id/tvCoordinates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/textPrimary"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:id="@+id/tvAccuracyInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_small"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/margin_small" />

                <!-- تقدم GPS -->
                <LinearLayout
                    android:id="@+id/gpsProgressLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <TextView
                        android:id="@+id/tvGpsProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/info"
                        android:layout_marginBottom="4dp" />

                    <ProgressBar
                        android:id="@+id/averagingProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="10"
                        android:progress="0" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capture_location"
                    app:icon="@drawable/ic_location"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/primary" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- زر الحفظ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_normal"
        android:text="@string/save_landmark"
        android:textSize="@dimen/text_size_subtitle"
        app:backgroundTint="@color/success" />

</LinearLayout>
