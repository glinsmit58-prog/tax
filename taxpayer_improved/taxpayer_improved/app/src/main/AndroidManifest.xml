<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Android 11+ Package Visibility:
      بدون هذه القائمة لا يرى التطبيق تطبيقات الكاميرا/الخرائط الأخرى
      وتعود launch() بنجاح=false بصمت (سبب رئيسي لعدم عمل التقاط الصورة)
    -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <package android:name="com.google.android.apps.maps" />
    </queries>

    <!-- صلاحيات الموقع -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- صلاحية الموقع في الخلفية (Android 10+) - لتتبّع الجولة عند إغلاق التطبيق -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground Service (لتشغيل خدمة التتبّع) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- إشعارات (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- منع الجهاز من النوم أثناء التتبّع (اختياري) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- صلاحية الكاميرا (للصور) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- صلاحيات التخزين (للاستيراد/التصدير) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- Android 13+ media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />

    <!-- الإنترنت (للخرائط) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- GPS Hardware feature (optional) -->
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <application
        android:name=".TaxGpsApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaxGPS"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- الشاشة الرئيسية -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- إضافة / تعديل مكلف -->
        <activity
            android:name=".ui.AddEditActivity"
            android:exported="false"
            android:label="@string/add_taxpayer"
            android:windowSoftInputMode="adjustResize" />

        <!-- تفاصيل المكلف -->
        <activity
            android:name=".ui.DetailActivity"
            android:exported="false"
            android:label="@string/taxpayer_details" />

        <!-- عرض الخريطة المتكاملة -->
        <activity
            android:name=".ui.MapViewActivity"
            android:exported="false"
            android:label="@string/map_view_title" />

        <!-- إضافة / تعديل معلم مرجعي -->
        <activity
            android:name=".ui.LandmarkActivity"
            android:exported="false"
            android:label="@string/add_landmark"
            android:windowSoftInputMode="adjustResize" />

        <!-- إدارة المعالم المرجعية -->
        <activity
            android:name=".ui.LandmarkListActivity"
            android:exported="false"
            android:label="@string/manage_landmarks" />

        <!-- ════════ خدمة تتبّع الجولات ════════ -->
        <service
            android:name=".tracking.TourTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- استقبال أزرار الإشعار (إيقاف الجولة من الإشعار) -->
        <receiver
            android:name=".tracking.TourActionReceiver"
            android:exported="false" />

        <!-- شاشة قائمة الجولات -->
        <activity
            android:name=".ui.ToursActivity"
            android:exported="false"
            android:label="@string/tours_title" />

        <!-- شاشة عرض الجولة على الخريطة (مع heatmap) -->
        <activity
            android:name=".ui.TourMapActivity"
            android:exported="false"
            android:label="@string/tour_view_map" />

        <!-- FileProvider للصور -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
